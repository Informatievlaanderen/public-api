{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:basisregisters:schemas:feeds:wijzigingen:postinfo:2026-01-01",
  "title": "Postinfo event data (create/update/delete)",
  "type": "object",
  "additionalProperties": false,
  "required": ["@id", "objectId", "naamruimte", "versieId", "nisCodes", "attributen"],
  "properties": {
    "@id": {
      "type": "string",
      "format": "uri",
      "description": "De persistente URI die dit postinfo-object identificeert."
    },
    "objectId": {
      "type": "string",
      "description": "De objectidentificator van de postinfo."
    },
    "naamruimte": {
      "type": "string",
      "format": "uri",
      "description": "De naamruimte waartoe dit object behoort."
    },
    "versieId": {
      "type": "string",
      "format": "date-time",
      "description": "Tijdstip van deze versie van het postinfo-object."
    },
    "nisCodes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{5}$"
      },
      "description": "De NIS-code(s) van de betrokken gemeente(n) op het moment van de wijziging. Bruikbaar voor client-side filtering."
    },
    "attributen": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribuutChange" },
      "description": "De gewijzigde attributen met hun oude en nieuwe waarde."
    }
  },
  "$defs": {
    "attribuutChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["naam", "oudeWaarde", "nieuweWaarde"],
      "properties": {
        "naam": {
          "type": "string",
          "description": "Naam van het gewijzigde attribuut."
        },
        "oudeWaarde": {
          "description": "De waarde van het attribuut vóór de wijziging. Null bij aanmaak."
        },
        "nieuweWaarde": {
          "description": "De waarde van het attribuut na de wijziging."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "naam": { "const": "postInfoStatus" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": {
                "type": ["null", "string"],
                "enum": [null, "inGebruik", "gehistoreerd"]
              },
              "nieuweWaarde": {
                "type": "string",
                "enum": ["inGebruik", "gehistoreerd"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "naam": { "const": "postnamen" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": {
                "type": "array",
                "items": { "$ref": "#/$defs/postnaam" }
              },
              "nieuweWaarde": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/postnaam" }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "naam": { "const": "gemeente.id" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": { "type": ["null", "string"] },
              "nieuweWaarde": { "type": ["null", "string"] }
            }
          }
        }
      ]
    },
    "postnaam": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spelling", "taal"],
      "properties": {
        "spelling": { "type": "string" },
        "taal": { "type": "string", "pattern": "^[a-z]{2}$" }
      }
    }
  }
}
