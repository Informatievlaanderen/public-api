{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:basisregisters:schemas:feeds:wijzigingen:straatnaam-transform:2026-01-01",
  "title": "Straatnaam transform data",
  "type": "object",
  "additionalProperties": false,
  "required": ["vanIds", "naarIds", "nisCodes"],
  "properties": {
    "vanIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Bron straatnaam identificator(en)."
    },
    "naarIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "description": "Doel straatnaam identificator(en)."
    },
    "nisCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{5}$",
        "description": "NIS code (5 digits)."
      }
    }
  }
}
