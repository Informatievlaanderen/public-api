{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:basisregisters:schemas:feeds:wijzigingen:gebouw:2026-01-01",
  "title": "Gebouw event data (create/update/delete)",
  "type": "object",
  "additionalProperties": false,
  "required": ["@id", "objectId", "naamruimte", "versieId", "nisCodes", "attributen"],
  "properties": {
    "@id": {
      "type": "string",
      "format": "uri",
      "description": "De persistente URI die dit gebouw-object identificeert."
    },
    "objectId": {
      "type": "string",
      "description": "De objectidentificator van het gebouw."
    },
    "naamruimte": {
      "type": "string",
      "format": "uri",
      "description": "De naamruimte waartoe dit object behoort."
    },
    "versieId": {
      "type": "string",
      "format": "date-time",
      "description": "Tijdstip van deze versie van het gebouw-object."
    },
    "nisCodes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{5}$"
      },
      "description": "De NIS-code(s) van de betrokken gemeente(n) op het moment van de wijziging. Bruikbaar voor client-side filtering."
    },
    "attributen": {
      "type": "array",
      "items": { "$ref": "#/$defs/attribuutChange" },
      "description": "De gewijzigde attributen met hun oude en nieuwe waarde."
    }
  },
  "$defs": {
    "attribuutChange": {
      "type": "object",
      "additionalProperties": false,
      "required": ["naam", "oudeWaarde", "nieuweWaarde"],
      "properties": {
        "naam": {
          "type": "string",
          "description": "Naam van het gewijzigde attribuut."
        },
        "oudeWaarde": {
          "description": "De waarde van het attribuut vóór de wijziging. Null bij aanmaak."
        },
        "nieuweWaarde": {
          "description": "De waarde van het attribuut na de wijziging."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "naam": { "const": "gebouwStatus" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": {
                "type": ["null", "string"],
                "enum": [null, "gepland", "inAanbouw", "nietGerealiseerd", "gerealiseerd", "gehistoreerd"]
              },
              "nieuweWaarde": {
                "type": "string",
                "enum": ["gepland", "inAanbouw", "nietGerealiseerd", "gerealiseerd", "gehistoreerd"]
              }
            }
          }
        },
        {
          "if": {
            "properties": { "naam": { "const": "gebouwGeometrie" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": {
                "oneOf": [
                  { "type": "null" },
                  { "$ref": "#/$defs/gebouwGeometrie" }
                ]
              },
              "nieuweWaarde": {
                "$ref": "#/$defs/gebouwGeometrie"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "naam": { "const": "geometrieMethode" } },
            "required": ["naam"]
          },
          "then": {
            "properties": {
              "oudeWaarde": {
                "type": ["null", "string"],
                "enum": [null, "ingeschetst", "ingemetenGRB"]
              },
              "nieuweWaarde": {
                "type": "string",
                "enum": ["ingeschetst", "ingemetenGRB"]
              }
            }
          }
        }
      ]
    },
    "gebouwGeometrie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "projectie", "gml"],
      "properties": {
        "type": {
          "type": "string",
          "const": "Polygon",
          "description": "Het type geometrie."
        },
        "projectie": {
          "type": "string",
          "description": "Het ruimtelijk referentiesysteem van de geometrie."
        },
        "gml": {
          "type": "string",
          "description": "De positie als GML-geometrie."
        }
      }
    }
  }
}
