{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:basisregisters:schemas:feeds:wijzigingen:adres-transform:2026-01-01",
  "title": "Adres transform data",
  "type": "object",
  "additionalProperties": false,
  "required": ["transformaties", "nisCodes"],
  "properties": {
    "transformaties": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/adresTransformatie"
      }
    },
    "nisCodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[0-9]{5}$",
        "description": "NIS code (5 digits)."
      }
    }
  },
  "$defs": {
    "adresTransformatie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vanId", "naarId"],
      "properties": {
        "vanId": {
          "type": "string",
          "minLength": 1
        },
        "naarId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
